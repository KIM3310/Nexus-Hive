# =============================================================================
# Nexus-Hive Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# ---------------------------------------------------------------------------
# Core Application
# ---------------------------------------------------------------------------
NEXUS_HIVE_DB_PATH=./nexus_enterprise.db
NEXUS_HIVE_OLLAMA_URL=http://localhost:11434/api/generate
NEXUS_HIVE_MODEL=phi3
NEXUS_HIVE_ROLE=analyst
NEXUS_HIVE_ALLOW_HEURISTIC_FALLBACK=1
NEXUS_HIVE_AUDIT_PATH=/tmp/nexus_hive_query_audit.jsonl
NEXUS_HIVE_LOG_LEVEL=INFO
NEXUS_HIVE_WAREHOUSE_ADAPTER=sqlite-demo

# ---------------------------------------------------------------------------
# Operator Authentication (optional)
# ---------------------------------------------------------------------------
# NEXUS_HIVE_OPERATOR_TOKEN=your-secret-token
# NEXUS_HIVE_OPERATOR_ALLOWED_ROLES=analyst,reviewer
# NEXUS_HIVE_OPERATOR_SESSION_COOKIE=nexus_hive_operator_session
# NEXUS_HIVE_OPERATOR_SESSION_SECRET=
# NEXUS_HIVE_OPERATOR_SESSION_TTL_SEC=43200
# NEXUS_HIVE_OPERATOR_SESSION_SECURE=false

# ---------------------------------------------------------------------------
# Runtime Store
# ---------------------------------------------------------------------------
# NEXUS_HIVE_RUNTIME_STORE_PATH=.runtime/nexus-hive-runtime-events.db
# NEXUS_HIVE_RUNTIME_STORE_BACKEND=sqlite

# ---------------------------------------------------------------------------
# Snowflake (env-var gated: set SNOWFLAKE_ACCOUNT to activate)
# ---------------------------------------------------------------------------
# SNOWFLAKE_ACCOUNT=your_account.us-east-1
# SNOWFLAKE_USER=your_username
# SNOWFLAKE_PASSWORD=your_password
# SNOWFLAKE_WAREHOUSE=COMPUTE_WH
# SNOWFLAKE_DATABASE=ANALYTICS
# SNOWFLAKE_SCHEMA=PUBLIC
# SNOWFLAKE_ROLE=ANALYST_ROLE

# ---------------------------------------------------------------------------
# Databricks (env-var gated: set DATABRICKS_HOST to activate)
# ---------------------------------------------------------------------------
# DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
# DATABRICKS_TOKEN=dapi_your_token_here
# DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your_warehouse_id
# DATABRICKS_CATALOG=main
# DATABRICKS_SCHEMA=default

# ---------------------------------------------------------------------------
# OpenAI (optional - for reviewer query demo)
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-your-key
# OPENAI_MODEL_PUBLIC=gpt-4.1-mini
# OPENAI_MODEL_REFRESH=gpt-5.2
# OPENAI_PUBLIC_DAILY_BUDGET_USD=4.0
# OPENAI_PUBLIC_MONTHLY_BUDGET_USD=120.0
# OPENAI_PUBLIC_RPM=6
# OPENAI_KILL_SWITCH=false
# OPENAI_MODERATION_ENABLED=true

# ---------------------------------------------------------------------------
# AWS (generic, for future use)
# ---------------------------------------------------------------------------
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# GCP (generic, for future use)
# ---------------------------------------------------------------------------
# GCP_PROJECT_ID=
# GCP_REGION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=
